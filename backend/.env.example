# ── Phase 0: Required immediately ─────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_KEY=<service_role_key>
EXOTEL_WEBHOOK_SECRET=<hmac_secret>
LOG_LEVEL=INFO

# ── Phase 0–1: Exotel (needed for live call or outbound API) ──────────────────
EXOTEL_ACCOUNT_SID=<sid>
EXOTEL_API_KEY=<key>
EXOTEL_API_TOKEN=<token>
EXOTEL_VIRTUAL_NUMBER=+91XXXXXXXXXX

# ── Phase 1: AI Pipeline ──────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Phase 2: Live Call ────────────────────────────────────────────────────────
SARVAM_API_KEY=<key>
OPENAI_API_KEY=sk-...       # only if copilot model decision = GPT-4o

# ── Phase 3: Auth ─────────────────────────────────────────────────────────────
JWT_SECRET=<64-char hex — generate: openssl rand -hex 32>

# ── Phase 4: WhatsApp + Storage ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=<token>
TWILIO_WHATSAPP_FROM=+1XXXXXXXXXX
CLOUDFLARE_ACCOUNT_ID=<id>
R2_ACCESS_KEY_ID=<key>
R2_SECRET_ACCESS_KEY=<secret>
R2_BUCKET_NAME=nishkriti-prod
R2_ENDPOINT_URL=https://<cloudflare_account_id>.r2.cloudflarestorage.com
UPSTASH_REDIS_URL=https://...
UPSTASH_REDIS_TOKEN=<token>

# ── Frontend only (frontend/.env.local — not this file) ───────────────────────
# NEXT_PUBLIC_API_URL=http://localhost:8000
